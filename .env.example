# ─────────────────────────────────────────────
#  IBM watsonx Orchestrate — Embedded Agent
# ─────────────────────────────────────────────
# No watsonx.ai Project ID is needed.
# The chat is handled by the embedded wxoLoader widget.
# Keep your IBM Cloud API key if you use other IBM services.
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# ─────────────────────────────────────────────
#  Flask Configuration
# ─────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_long_random_secret_key
FLASK_ENV=development
FLASK_DEBUG=True

# ─────────────────────────────────────────────
#  App Settings
# ─────────────────────────────────────────────
APP_NAME=TravelPlannerAI
